# --- InsForge (client — rotate any key previously committed to git) ---
NEXT_PUBLIC_INSFORGE_BASE_URL=https://YOUR_PROJECT.insforge.app
NEXT_PUBLIC_INSFORGE_ANON_KEY=your_insforge_anon_jwt

# --- Firebase (client) ---
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Firebase Admin (server, required for /api/orders writes) ---
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
# Keep escaped newlines (\n) if stored in plain env files
FIREBASE_ADMIN_PRIVATE_KEY=

# --- Sanity ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-05-03

# --- Operator admin (server only — never use NEXT_PUBLIC_*) ---
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=generate_a_long_random_password
ADMIN_SESSION_SECRET=min_32_chars_random_secret_for_hmac

# --- Upstash (optional strict mode) ---
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Set to "true" to return 503 on /api/auth/login and /api/auth/admin-login when Redis is down or Redis errors occur (after attempts).
REQUIRE_UPSTASH_REDIS=false

# --- Webhooks ---
# Production: required on POST /api/webhooks/vercel (Authorization: Bearer … or header x-webhook-secret)
WEBHOOK_SECRET=
VERCEL_TEAM_SLUG=your-team
VERCEL_PROJECT_NAME=souq-pro-app

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
